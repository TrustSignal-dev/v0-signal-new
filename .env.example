BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx
REVIEW_DASHBOARD_TOKEN=change-me-review-token
NEXT_PUBLIC_REVIEW_REPO_URL=https://github.com/TrustSignal-dev/TrustSignal-docs
NEXT_PUBLIC_TRUSTSIGNAL_APP_URL=
DRATA_PARTNER_PASSWORD=change-me-drata
SCRUT_PARTNER_PASSWORD=change-me-scrut
VANTA_PARTNER_PASSWORD=change-me-vanta
PARTNER_SESSION_SECRET=change-me-long-random-secret
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# App URL used for OAuth callbacks and Stripe redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Auth + RLS (user-facing routes must use anon key + session)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxx

# Service role is restricted to webhook-only server handlers
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxx

# Optional pepper added to API key hashing
API_KEY_PEPPER=change-me-strong-pepper

# Stripe billing
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_ID=price_xxxxx

# TrustSignal API — internal connection for usage stats
# TRUSTSIGNAL_API_BASE_URL: base URL of the TrustSignal backend API
# TRUSTSIGNAL_DASHBOARD_API_KEY: a read-scoped API key created for dashboard internal use
TRUSTSIGNAL_API_BASE_URL=https://api.trustsignal.dev
TRUSTSIGNAL_DASHBOARD_API_KEY=replace-with-read-scoped-api-key

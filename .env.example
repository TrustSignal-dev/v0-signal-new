BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx
REVIEW_DASHBOARD_TOKEN=change-me-review-token
NEXT_PUBLIC_REVIEW_REPO_URL=https://github.com/TrustSignal-dev/TrustSignal-docs
NEXT_PUBLIC_TRUSTSIGNAL_APP_URL=
DRATA_PARTNER_PASSWORD=change-me-drata
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# App URL used for OAuth callbacks and Stripe redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Auth + RLS (user-facing routes must use anon key + session)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxx

# Service role is restricted to webhook-only server handlers
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxx

# Optional pepper added to API key hashing
API_KEY_PEPPER=change-me-strong-pepper

# Stripe billing
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_ID=price_xxxxx
STRIPE_PRICE_ID_PRO=price_xxxxx

# TrustSignal API — internal connection for usage stats
# TRUSTSIGNAL_API_BASE_URL: base URL of the TrustSignal backend API
# TRUSTSIGNAL_DASHBOARD_API_KEY: a read-scoped API key created for dashboard internal use
TRUSTSIGNAL_API_BASE_URL=https://api.trustsignal.dev
TRUSTSIGNAL_DASHBOARD_API_KEY=replace-with-read-scoped-api-key

# Admin authentication
# TRUSTSIGNAL_ADMIN_PASSWORD: password used to access the founder/admin console
TRUSTSIGNAL_ADMIN_PASSWORD=your-admin-password-here
# TRUSTSIGNAL_OPERATOR_USER_ID: Supabase user id used for admin-created keys
TRUSTSIGNAL_OPERATOR_USER_ID=your-operator-user-id-here
# TRUSTSIGNAL_ADMIN_API_KEY: privileged API key for admin receipt lookup
TRUSTSIGNAL_ADMIN_API_KEY=your-admin-api-key-here

# Session
# SESSION_SECRET: secret used to sign server-side session tokens (32+ chars)
SESSION_SECRET=your-session-secret-32-chars-minimum

# TrustSignal API (alternate name used by receipt verify route)
TRUSTSIGNAL_API_URL=https://api.trustsignal.dev

# Demo Playground (app/demo — served at demo.trustsignal.dev)
# A scoped API key used exclusively by the public integrity demo proxy.
# The proxy rate-limits to 30 req/min per IP and never exposes this key client-side.
DEMO_API_KEY=replace-with-demo-scoped-api-key
